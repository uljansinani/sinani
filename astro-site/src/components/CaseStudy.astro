---
import { getCollection } from 'astro:content';

const caseStudies = (await getCollection('projects'))
  .filter((p) => p.data.isCaseStudy)
  .sort((a, b) => a.data.order - b.data.order);

function caseStudyMetricHtml(metric: string) {
  return metric.replace(/<span>/g, '<span style="color:var(--signal)">');
}

function assetPath(path: string) {
  return path.startsWith('/') ? path : `/${path}`;
}

function sectionId(cardHref: string) {
  return cardHref.startsWith('#') ? cardHref.slice(1) : cardHref;
}
---

{
  caseStudies.map((project) => {
    const {
      cardHref,
      title,
      desc,
      metric,
      heroImage,
      heroImageAlt,
      heroImageCredit,
      heroImageCreditUrl,
      heroFigCaption,
    } = project.data;
    const showHeroFigure = heroImage?.endsWith('.jpg');

    return (
      <section id={sectionId(cardHref)} class="case-study reveal">
        <h3>{title}</h3>
        {showHeroFigure && heroImage && (
          <figure class="card-fig">
            <picture>
              <source srcset={assetPath(heroImage.replace(/\.jpg$/, '.webp'))} type="image/webp" />
              <img
                src={assetPath(heroImage)}
                alt={heroImageAlt}
                width="1372"
                height="760"
                loading="lazy"
              />
            </picture>
            <figcaption class="fig-caption">
              {heroFigCaption && <span class="fig-caption-desc">{heroFigCaption}</span>}
              <span class="fig-credit">
                Photo:{' '}
                <a href={heroImageCreditUrl} target="_blank" rel="noopener">
                  {heroImageCredit}
                </a>
              </span>
            </figcaption>
          </figure>
        )}
        {desc.map((text) => (
          <p>{text}</p>
        ))}
        {metric && <p set:html={caseStudyMetricHtml(metric)} />}
        <a class="back" href="#work">← back to work</a>
      </section>
    );
  })
}
