---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);

function assetPath(path: string) {
  return path.startsWith('/') ? path : `/${path}`;
}
---

{
  projects.map((project) => {
    const {
      id_code,
      title,
      domain,
      stack,
      status,
      desc,
      metric,
      cardHref,
      cardHrefExternal,
      cardAriaLabel,
      cardPeek,
      cardPeekCaption,
      heroImage,
      heroImageAlt,
      heroImageCredit,
      heroImageCreditUrl,
      heroFigCaption,
    } = project.data;
    const isPhdWrap = cardHref === '#phd-biomech';
    const showHeroFigure = heroImage?.endsWith('.jpg');
    const showInlineImage = heroImage?.endsWith('.svg');

    if (isPhdWrap) {
      return (
        <article class="card card--link">
          <a class="card-wrap" href={cardHref}>
            <div class="idx">{id_code}</div>
            <h3>{title}</h3>
            {desc.map((text) => (
              <p class="desc">{text}</p>
            ))}
            {metric && <div class="metric" set:html={metric} />}
            {cardPeek && <div class="card-peek">{cardPeek}</div>}
            <div class="meta">
              <span class="tag">{domain}</span>
              <span class="tag">{stack.join(' · ')}</span>
              <span class="tag status">● {status}</span>
            </div>
          </a>
        </article>
      );
    }

    return (
      <article class="card card--link">
        <a
          class="card-stretch"
          href={cardHref}
          {...(cardHrefExternal ? { target: '_blank', rel: 'noopener' } : {})}
          aria-label={cardAriaLabel ?? title}
        />
        <div class="idx">{id_code}</div>
        <h3>
          {title}
          {cardHrefExternal && (
            <a class="ext" href={cardHref} target="_blank" rel="noopener">
              permissioning.ai ↗
            </a>
          )}
          {cardHref === '/latent-audit' && (
            <a class="ext" href="/latent-audit">Read note ↗</a>
          )}
        </h3>
        {showHeroFigure && heroImage && (
          <figure class="card-fig">
            <picture>
              <source srcset={assetPath(heroImage.replace(/\.jpg$/, '.webp'))} type="image/webp" />
              <img src={assetPath(heroImage)} alt={heroImageAlt} width="1372" height="760" loading="lazy" />
            </picture>
            <figcaption class="fig-caption">
              {heroFigCaption && <span class="fig-caption-desc">{heroFigCaption}</span>}
              <span class="fig-credit">
                Photo:{' '}
                <a class="ext" href={heroImageCreditUrl} target="_blank" rel="noopener">
                  {heroImageCredit}
                </a>
              </span>
            </figcaption>
          </figure>
        )}
        {showInlineImage && heroImage && (
          <img src={assetPath(heroImage)} alt={heroImageAlt} loading="lazy" width="800" height="500" />
        )}
        {desc.map((text) => (
          <p class="desc">{text}</p>
        ))}
        {metric && <div class="metric" set:html={metric} />}
        {cardPeek && !cardPeekCaption && <div class="card-peek">{cardPeek}</div>}
        {cardPeek && cardPeekCaption && (
          <div class="card-peek">
            {cardPeek}
            <div class="peek-cap">{cardPeekCaption}</div>
          </div>
        )}
        <div class="meta">
          <span class="tag">{domain}</span>
          <span class="tag">{stack.join(' · ')}</span>
          <span class="tag status">● {status}</span>
        </div>
      </article>
    );
  })
}
