---
import { getCollection } from 'astro:content';

const rows = (await getCollection('experience')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<div class="xp reveal">
  {
    rows.map((row) => (
      <div class="xp-row">
        <div class="yr">{row.data.dateRange}</div>
        <div>
          <div class="role">{row.data.role}</div>
          <div class="org">{row.data.orgLine}</div>
        </div>
      </div>
    ))
  }
</div>
